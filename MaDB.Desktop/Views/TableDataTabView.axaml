<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MaDB.Desktop.ViewModels"
             x:Class="MaDB.Desktop.Views.TableDataTabView"
             x:DataType="vm:TableDataTabViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
        <TextBlock Text="{Binding Summary}"
                   FontSize="12"
                   Foreground="{DynamicResource SecondaryTextColor}"
                   Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage.Length}"
                   Foreground="{DynamicResource ErrorTextColor}"
                   FontSize="12"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>
        <DataGrid x:Name="RowsGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  Background="{DynamicResource EditorBackgroundColor}"
                  Foreground="{DynamicResource EditorForegroundColor}"
                  BorderBrush="{DynamicResource EditorBorderColor}"
                  BorderThickness="1"
                  CellEditEnding="OnCellEditEnding"/>
        <Grid Grid.Row="3"
              Margin="0,8,0,0"
              ColumnDefinitions="Auto,Auto,Auto,*,Auto"
              ColumnSpacing="8">
            <Button Command="{Binding LoadDataCommand}"
                    Classes="SecondaryAction">
                <TextBlock Text="{DynamicResource TxtRefreshData}"/>
            </Button>

            <Button Grid.Column="1"
                    Command="{Binding AddRowCommand}"
                    Classes="SecondaryAction">
                <TextBlock Text="{DynamicResource TxtAddRow}"/>
            </Button>

            <Button Grid.Column="2"
                    Command="{Binding DeleteSelectedRowCommand}"
                    Classes="DestructiveAction">
                <TextBlock Text="{DynamicResource TxtDeleteRow}"/>
            </Button>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <Button Command="{Binding PreviousPageCommand}"
                        Classes="SecondaryAction"
                        IsEnabled="{Binding CanGoPreviousPage}"
                        Padding="12,8">
                    <TextBlock Text="◀" FontSize="11"/>
                </Button>
                <TextBlock Text="{Binding PageSummary}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextColor}"/>
                <Button Command="{Binding NextPageCommand}"
                        Classes="SecondaryAction"
                        IsEnabled="{Binding CanGoNextPage}"
                        Padding="12,8">
                    <TextBlock Text="▶" FontSize="11"/>
                </Button>
            </StackPanel>

            <Button Grid.Column="4"
                    Command="{Binding SaveChangesCommand}"
                    Classes="PrimaryAction"
                    IsVisible="{Binding HasUnsavedChanges}">
                <TextBlock Text="{DynamicResource TxtSaveChanges}"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
