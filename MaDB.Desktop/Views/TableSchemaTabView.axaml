<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MaDB.Desktop.ViewModels"
             x:Class="MaDB.Desktop.Views.TableSchemaTabView"
             x:DataType="vm:TableSchemaTabViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12">
        <TextBlock Text="{Binding TableType}"
                   FontSize="12"
                   Foreground="{DynamicResource SecondaryTextColor}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   IsVisible="{Binding ErrorMessage.Length}"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource TxtColumns}"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextColor}"
                   Margin="0,0,0,8"/>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Columns}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  Background="{DynamicResource EditorBackgroundColor}"
                  Foreground="{DynamicResource EditorForegroundColor}"
                  BorderBrush="{DynamicResource EditorBorderColor}"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource TxtColumnName}" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="{DynamicResource TxtDataType}" Binding="{Binding DataType}" Width="120"/>
                <DataGridTextColumn Header="{DynamicResource TxtNullable}" Binding="{Binding NullableText}" Width="80"/>
                <DataGridTextColumn Header="{DynamicResource TxtPrimaryKey}" Binding="{Binding PrimaryKeyText}" Width="60"/>
                <DataGridTextColumn Header="{DynamicResource TxtDefaultValue}" Binding="{Binding DefaultValue}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
