<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Base Theme Resources -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <!-- Background Colors -->
            <Color x:Key="AppBackgroundColor">#07111E</Color>
            <Color x:Key="CardBackgroundColor">#0D1727</Color>
            <Color x:Key="InnerCardBackgroundColor">#132033</Color>
            <Color x:Key="HeaderBackgroundColor">#101A2D</Color>
            <Color x:Key="FooterBackgroundColor">#101A2D</Color>
            
            <!-- Border Colors -->
            <Color x:Key="CardBorderColor">#223149</Color>
            <Color x:Key="InnerCardBorderColor">#24324A</Color>
            
            <!-- Text Colors -->
            <Color x:Key="PrimaryTextColor">#F4F8FF</Color>
            <Color x:Key="SecondaryTextColor">#93A4BC</Color>
            <Color x:Key="TertiaryTextColor">#7890AD</Color>
            <Color x:Key="AccentTextColor">#8EE7FF</Color>
            <Color x:Key="SuccessTextColor">#7EE2A5</Color>
            
            <!-- Button Colors -->
            <Color x:Key="PrimaryButtonBackgroundColor">#5EEAD4</Color>
            <Color x:Key="PrimaryButtonForegroundColor">#042F2E</Color>
            <Color x:Key="SecondaryButtonBackgroundColor">#1A2C44</Color>
            <Color x:Key="SecondaryButtonForegroundColor">#EEF5FF</Color>
            
            <!-- Badge Colors -->
            <Color x:Key="BadgeBackgroundColor">#15253A</Color>
            <Color x:Key="BadgeForegroundColor">#8EE7FF</Color>
            
            <!-- Editor Colors -->
            <Color x:Key="EditorBackgroundColor">#0A1320</Color>
            <Color x:Key="EditorForegroundColor">#ECF4FF</Color>
            <Color x:Key="EditorBorderColor">#2A3A54</Color>
            <Color x:Key="EditorCaretColor">#8EE7FF</Color>
            <Color x:Key="EditorSelectionColor">#1D3B5C</Color>
        </ResourceDictionary>
        
        <ResourceDictionary x:Key="Light">
            <!-- Background Colors -->
            <Color x:Key="AppBackgroundColor">#F5F7FA</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="InnerCardBackgroundColor">#F8FAFC</Color>
            <Color x:Key="HeaderBackgroundColor">#FFFFFF</Color>
            <Color x:Key="FooterBackgroundColor">#FFFFFF</Color>
            
            <!-- Border Colors -->
            <Color x:Key="CardBorderColor">#E2E8F0</Color>
            <Color x:Key="InnerCardBorderColor">#E2E8F0</Color>
            
            <!-- Text Colors -->
            <Color x:Key="PrimaryTextColor">#1E293B</Color>
            <Color x:Key="SecondaryTextColor">#64748B</Color>
            <Color x:Key="TertiaryTextColor">#94A3B8</Color>
            <Color x:Key="AccentTextColor">#0EA5E9</Color>
            <Color x:Key="SuccessTextColor">#10B981</Color>
            
            <!-- Button Colors -->
            <Color x:Key="PrimaryButtonBackgroundColor">#0EA5E9</Color>
            <Color x:Key="PrimaryButtonForegroundColor">#FFFFFF</Color>
            <Color x:Key="SecondaryButtonBackgroundColor">#E2E8F0</Color>
            <Color x:Key="SecondaryButtonForegroundColor">#1E293B</Color>
            
            <!-- Badge Colors -->
            <Color x:Key="BadgeBackgroundColor">#E0F2FE</Color>
            <Color x:Key="BadgeForegroundColor">#0EA5E9</Color>
            
            <!-- Editor Colors -->
            <Color x:Key="EditorBackgroundColor">#FFFFFF</Color>
            <Color x:Key="EditorForegroundColor">#1E293B</Color>
            <Color x:Key="EditorBorderColor">#CBD5E1</Color>
            <Color x:Key="EditorCaretColor">#0EA5E9</Color>
            <Color x:Key="EditorSelectionColor">#BAE6FD</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
    
</ResourceDictionary>