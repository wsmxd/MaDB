<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <system:String x:Key="TxtAppTitle">MaDB Desktop</system:String>
    <system:String x:Key="TxtAppSubtitle">Provider-first database workspace</system:String>
    <system:String x:Key="TxtLangToggle">中 / EN</system:String>
    <system:String x:Key="TxtTargetLabel">Target</system:String>
    <system:String x:Key="TxtConnectionLabel">Connection</system:String>
    <system:String x:Key="TxtQueryModeLabel">Query mode</system:String>
    
    <system:String x:Key="TxtConnectionsTitle">Connections</system:String>
    <system:String x:Key="TxtConnectionsSub">Saved targets and access modes</system:String>
    <system:String x:Key="TxtActiveBadge">ACTIVE</system:String>
    <system:String x:Key="TxtTableBrowserTitle">Tables</system:String>
    <system:String x:Key="TxtTableBrowserSub">Browse tables and views from the live SQLite database</system:String>
    <system:String x:Key="TxtTableDataTab">Table data</system:String>
    <system:String x:Key="TxtQueryResultTab">Query result</system:String>
    
    <system:String x:Key="TxtWorkspaceTitle">Workspace</system:String>
    <system:String x:Key="TxtWorkspaceSub">Write SQL, preview output, and wire execution later</system:String>
    <system:String x:Key="TxtProviderLabel">Provider</system:String>
    <system:String x:Key="TxtAccessLabel">Access</system:String>
    <system:String x:Key="TxtRowCapLabel">Row cap</system:String>
    
    <system:String x:Key="TxtSqlEditorTitle">SQL Editor</system:String>
    <system:String x:Key="TxtSqlEditorSub">Preview only for now</system:String>
    
    <system:String x:Key="TxtExecuteQueryBtn">Execute</system:String>
    <system:String x:Key="TxtRefreshSchemaBtn">Refresh schema</system:String>
    <system:String x:Key="TxtResultPreviewTitle">Live query result</system:String>
    
    <system:String x:Key="TxtActivityTitle">Activity</system:String>
    <system:String x:Key="TxtActivitySub">Latest connection and workspace events</system:String>

    <system:String x:Key="TxtNewSqlEditor">New Query</system:String>
    <system:String x:Key="TxtNoTabsOpen">No tabs open</system:String>
    <system:String x:Key="TxtNoTabsHint">Double-click a table on the left to view data, or click the button above to create a SQL editor</system:String>
    <system:String x:Key="TxtRefreshData">Refresh</system:String>

    <!-- strings for view model -->
    <system:String x:Key="VmSchemaSummary">{0} objects loaded</system:String>
    <system:String x:Key="VmCapSummary">100 rows</system:String>
    <system:String x:Key="VmPreviewHint">The current SQL runs against the live SQLite database.</system:String>
    <system:String x:Key="VmResultSummary">{0} rows returned.</system:String>
    <system:String x:Key="VmFooterSummary">SQLite workspace ready with {0} objects.</system:String>
    <system:String x:Key="VmStatusConnecting">Connecting...</system:String>
    <system:String x:Key="VmStatusReady">Ready.</system:String>
    <system:String x:Key="VmStatusError">Database error:</system:String>
    <system:String x:Key="VmMsgWorkspaceReady">Database workspace initialized.</system:String>
    <system:String x:Key="VmMsgSchemaLoaded">Loaded {0} schema objects.</system:String>
    <system:String x:Key="VmMsgQueryExecuted">Executed live query and returned {0} rows.</system:String>
    <system:String x:Key="VmSelectedTableEmpty">Select a table to view its rows.</system:String>
    <system:String x:Key="VmSelectedTableSummary">{0} · {1} rows</system:String>
    <system:String x:Key="VmMsgTableLoaded">Opened table {0}.</system:String>
</ResourceDictionary>