<Styles xmlns="https://github.com/avaloniaui"
        xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Design.PreviewWith>
        <Border Padding="20" Background="{DynamicResource AppBackgroundColor}">
            <StackPanel Spacing="10">
                <Border Classes="Card">
                    <TextBlock Text="Card Panel" Foreground="{DynamicResource PrimaryTextColor}"/>
                </Border>
                <Border Classes="InnerCard">
                    <TextBlock Text="Inner Card Panel" Foreground="{DynamicResource PrimaryTextColor}"/>
                </Border>
                <ae:TextEditor Classes="SqlEditor" Text="SELECT * FROM table;" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Base Card Container -->
    <Style Selector="Border.Card">
        <Setter Property="Padding" Value="18"/>
        <Setter Property="CornerRadius" Value="22"/>
        <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Inner Card / Element Frame -->
    <Style Selector="Border.InnerCard">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Background" Value="{DynamicResource InnerCardBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InnerCardBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Specific SQL Editor TextBox Style -->
    <Style Selector="TextBox.SqlEditor">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New, monospace"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="140"/>
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBorderColor}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource EditorCaretColor}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource EditorSelectionColor}"/>
        <Setter Property="SelectionForegroundBrush" Value="{DynamicResource PrimaryTextColor}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="AcceptsTab" Value="True"/>
    </Style>

    <Style Selector="ae|TextEditor.SqlEditor">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New, monospace"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="140"/>
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBorderColor}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Button.PrimaryAction">
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundColor}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.SecondaryAction">
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundColor}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.LanguageToggle">
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Background" Value="{DynamicResource SecondaryButtonBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource SecondaryButtonForegroundColor}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    
    <!-- Fix TextBox Hover and Focus states so they don't break our dark theme -->
    <Style Selector="TextBox.SqlEditor:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentTextColor}"/>
    </Style>
    
    <Style Selector="TextBox.SqlEditor:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource EditorBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundColor}"/>
    </Style>

    <!-- DataGrid dark theme overrides -->
    <Style Selector="DataGrid">
        <Setter Property="RowBackground" Value="{DynamicResource EditorBackgroundColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource EditorBorderColor}"/>
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundColor}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InnerCardBorderColor}"/>
    </Style>

    <Style Selector="DataGridCell:selected">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
        <Setter Property="Background" Value="{DynamicResource EditorSelectionColor}"/>
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
        <Setter Property="Background" Value="{DynamicResource InnerCardBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InnerCardBorderColor}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource EditorForegroundColor}"/>
    </Style>

    <Style Selector="DataGridRow:selected">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
        <Setter Property="Background" Value="{DynamicResource EditorSelectionColor}"/>
    </Style>

    <!-- MenuFlyout styles -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="MinWidth" Value="160"/>
    </Style>

    <Style Selector="MenuFlyoutPresenter:pointerover">
        <Setter Property="Background" Value="{DynamicResource CardBackgroundColor}"/>
    </Style>

    <!-- MenuItem styles -->
    <Style Selector="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource BadgeBackgroundColor}"/>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource BadgeBackgroundColor}"/>
    </Style>

    <Style Selector="MenuItem:pressed /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundColor}"/>
    </Style>

    <Style Selector="MenuItem:disabled">
        <Setter Property="Foreground" Value="{DynamicResource TertiaryTextColor}"/>
    </Style>

    <!-- Separator in menu -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{DynamicResource CardBorderColor}"/>
        <Setter Property="Margin" Value="4,2"/>
    </Style>
</Styles>
